---

---

<footer class="bg-[#1a1a1a] text-white pt-16 pb-8 border-t border-white/5">
  <div class="container mx-auto px-4 max-w-7xl">
    <!-- Main Grid: 4 Columns -->
    <div
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 text-center mb-16"
    >
      <!-- 1. Contact -->
      <div class="flex flex-col items-center">
        <div class="text-gold text-3xl mb-4">
          <!-- Phone Icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-8 w-8"
            fill="currentColor"
            viewBox="0 0 24 24"
            ><path
              d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 00-1.01.24l-1.57 1.97c-2.83-1.44-5.15-3.75-6.59-6.59l1.97-1.57c.23-.23.33-.55.24-1.01a17.3 17.3 0 00-.56-3.53.995.995 0 00-1-.75h-3.5c-.55 0-1 .45-1 1C4.25 14.84 13.16 23.75 22 23.75c.55 0 1-.45 1-1v-3.5c0-.51-.41-.95-.91-.87h-.08z"
            ></path></svg
          >
        </div>
        <h3 class="font-display text-2xl tracking-wider mb-2">Contattaci</h3>
        <p class="text-gray-300 text-sm font-semibold">
          pachamamanovoandina@gmail.com
        </p>
        <p class="text-gray-300 text-sm font-semibold">328 428 1204</p>
        <p class="text-gray-300 text-sm font-semibold">02 39444119</p>
      </div>

      <!-- 2. Location -->
      <div class="flex flex-col items-center">
        <a
          href="https://maps.app.goo.gl/v2jBhGXAocRa5UNUA"
          target="_blank"
          class="flex flex-col items-center hover:text-gold transition-colors group"
        >
          <div
            class="text-gold text-3xl mb-4 group-hover:scale-110 transition-transform"
          >
            <!-- Map Pin Icon -->
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-8 w-8"
              fill="currentColor"
              viewBox="0 0 24 24"
              ><path
                d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
              ></path></svg
            >
          </div>
          <h3 class="font-display text-2xl tracking-wider mb-2">
            Vieni a trovarci
          </h3>
          <p
            class="text-gray-300 group-hover:text-white text-sm font-semibold transition-colors"
          >
            Via dei Tulipani 1, Milano
          </p>
        </a>
      </div>

      <!-- 3. WhatsApp -->
      <div class="flex flex-col items-center">
        <div class="text-gold text-3xl mb-4">
          <!-- WhatsApp Icon (Fixed) -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-8 w-8"
            fill="currentColor"
            viewBox="0 0 24 24"
            ><path
              d="M19.05 4.91A9.816 9.816 0 0 0 12.04 2c-5.46 0-9.91 4.45-9.91 9.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.8 3.08 1.22 4.74 1.22c5.46 0 9.91-4.45 9.91-9.91c0-2.65-1.03-5.14-2.9-7.02m-7.01 15.24c-1.48 0-2.93-.4-4.2-1.15l-.3-.18l-3.12.82l.83-3.04l-.2-.31a8.264 8.264 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.24-8.24c2.2 0 4.27.86 5.82 2.42a8.183 8.183 0 0 1 2.41 5.83c.02 4.54-3.68 8.23-8.22 8.23m4.52-6.16c-.25-.12-1.47-.72-1.69-.81c-.23-.08-.39-.12-.56.12c-.17.25-.64.81-.78.97c-.14.17-.29.19-.54.06c-.25-.12-1.05-.39-1.99-1.23c-.74-.66-1.23-1.47-1.38-1.72c-.14-.25-.02-.38.11-.51c.11-.11.25-.29.37-.43s.17-.25.25-.41c.08-.17.04-.31-.02-.43s-.56-1.34-.76-1.84c-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31c-.22.25-.86.85-.86 2.07c0 1.22.89 2.4 1.01 2.56c.12.17 1.75 2.67 4.23 3.74c.59.26 1.05.41 1.41.52c.59.19 1.13.16 1.56.1c.48-.06 1.47-.6 1.67-1.18c.21-.58.21-1.07.14-1.18s-.22-.16-.47-.28"
            ></path></svg
          >
        </div>
        <h3 class="font-display text-2xl tracking-wider mb-2">
          Prenota su WhatsApp
        </h3>
        <a
          href="https://wa.me/393284281204"
          target="_blank"
          class="text-gray-300 text-sm font-semibold hover:text-gold transition-colors"
          >Clicca qui</a
        >
      </div>

      <!-- 4. Hours (Orari) -->
      <div class="flex flex-col items-center">
        <div class="text-gold text-3xl mb-4">
          <!-- Clock Icon -->
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-8 w-8"
            fill="currentColor"
            viewBox="0 0 24 24"
            ><path
              d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z"
            ></path></svg
          >
        </div>
        <h3 class="font-display text-2xl tracking-wider mb-2">Orari</h3>
        <div
          class="text-gray-300 text-sm font-semibold space-y-1 text-left inline-block"
        >
          <div class="grid grid-cols-[80px_1fr] gap-x-2">
            <span class="text-right">lunedì</span>
            <span>12–15:30, 17:30–23:30</span>
            <span class="text-right">martedì</span>
            <span>12–15:30, 17:30–23:30</span>
            <span class="text-right">mercoledì</span>
            <span>Chiuso</span>
            <span class="text-right">giovedì</span>
            <span>12–15:30, 17:30–23:30</span>
            <span class="text-right">venerdì</span>
            <span>12–15:30, 17:30–23:30</span>
            <span class="text-right">sabato</span>
            <span>12:00 – 23:30</span>
            <span class="text-right">domenica</span>
            <span>12:00 – 23:30</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Decorative Pattern Strip -->
    <div
      class="w-full max-w-7xl mx-auto h-24 mb-8 bg-center"
      style="background-image: url('/images/home/pattern2.png'); background-repeat: no-repeat; background-size: contain;"
    >
    </div>

    <!-- Social & Copyright -->
    <div class="text-center">
      <h4 class="font-body font-bold text-white mb-4">Seguici su</h4>
      <div class="flex justify-center gap-6 mb-8">
        <!-- Facebook -->
        <a
          href="https://www.facebook.com/ristorante.pachamama.milano/"
          target="_blank"
          class="bg-gold text-black p-2 rounded hover:bg-white hover:text-black transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="currentColor"
            viewBox="0 0 24 24"
            ><path
              d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
            ></path></svg
          >
        </a>
        <!-- Instagram -->
        <a
          href="https://www.instagram.com/pachamama_milano/"
          target="_blank"
          class="bg-gold text-black p-2 rounded hover:bg-white hover:text-black transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="currentColor"
            viewBox="0 0 24 24"
            ><path
              d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
            ></path></svg
          >
        </a>
        <!-- TikTok -->
        <a
          href="https://www.tiktok.com/@pachamama.milano"
          target="_blank"
          class="bg-gold text-black p-2 rounded hover:bg-white hover:text-black transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-6 w-6"
            fill="currentColor"
            viewBox="0 0 24 24"
            ><path
              d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5 20.1a6.34 6.34 0 0 0 10.86-4.43v-7a8.16 8.16 0 0 0 4.77 1.52v-3.4a4.85 4.85 0 0 1-1-.1z"
            ></path></svg
          >
        </a>
      </div>

      <p class="text-xs text-gray-300 mb-1 font-semibold">P.IVA 10356940964</p>
      <p class="text-xs text-gray-300 font-semibold">
        © 2024 Pachamama Milano - Tutti i diritti riservati.
      </p>
      <div
        class="flex justify-center gap-4 mt-2 text-xs text-gray-300 font-semibold"
      >
        <a
          href="https://www.iubenda.com/privacy-policy/94099485"
          target="_blank"
          class="hover:text-gold i-ubenda">Privacy Policy</a
        >
        <span>-</span>
        <a
          href="https://www.iubenda.com/privacy-policy/94099485/cookie-policy"
          target="_blank"
          class="hover:text-gold i-ubenda">Cookie Policy</a
        >
      </div>
    </div>
  </div>
</footer>
