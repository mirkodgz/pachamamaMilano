---

---

<header
  class="bg-dark py-1 px-6 fixed top-0 w-full z-50 flex justify-between items-center border-b border-white/10"
>
  <a href="/" class="block">
    <!-- Logo Placeholder -->
    <img
      src="/logo.png"
      alt="Pachamama Milano"
      class="h-14 md:h-16 w-auto"
      onerror="this.src='https://placehold.co/150x50/black/gold?text=PACHAMAMA'"
    />
  </a>

  <!-- Horizontal Navigation - Professional & Clean (Desktop) -->
  <nav class="hidden lg:flex items-center justify-center gap-6">
    <a
      href="/"
      class="hidden text-white hover:text-gold transition-colors font-display text-base uppercase tracking-widest"
      >Home</a
    >
    <a
      href="/chi-siamo"
      class="text-white hover:text-gold transition-colors font-display text-base uppercase tracking-widest"
      >Chi Siamo</a
    >
    <a
      href="/gallery"
      class="text-white hover:text-gold transition-colors font-display text-base uppercase tracking-widest"
      >Gallery</a
    >

    <a
      href="/gift-card"
      class="text-white hover:text-gold transition-colors font-display text-base uppercase tracking-widest"
      >Gift Card</a
    >

    <a
      href="/menu"
      class="text-white hover:text-gold transition-colors font-display text-base uppercase tracking-widest"
      >Menu</a
    >
    <a
      href="/bar"
      class="hidden text-white hover:text-gold transition-colors font-display text-base uppercase tracking-widest"
      >Bar</a
    >

    <!-- User Navigation -->
    <div
      id="user-nav-desktop"
      class="flex items-center gap-4 ml-4 pl-4 border-l border-white/10"
    >
      <a
        href="/prenota"
        class="bg-gold text-dark text-[10px] sm:text-xs font-bold py-2.5 px-6 rounded uppercase tracking-widest hover:bg-white transition-all shadow-md"
      >Prenota</a>

      <!-- User Dropdown (Always visible icon when logged out, initials when logged in) -->
      <div class="relative" id="header-user-dropdown-container">
        <button
          id="header-user-trigger"
          class="flex items-center gap-2 text-white hover:text-gold transition-colors focus:outline-none"
        >
          <!-- Logged out icon -->
          <svg id="header-user-icon" xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
          </svg>

          <!-- Logged in initials -->
          <div id="header-user-initials" class="hidden bg-gold text-dark font-display font-bold w-9 h-9 rounded-full items-center justify-center text-sm uppercase shadow-sm border border-gold/50">
            -
          </div>

          <!-- Caret -->
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform duration-200" id="header-user-caret" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>

        <!-- Dropdown Menu -->
        <div id="header-user-menu" class="absolute top-full mt-4 w-60 bg-dark border border-white/10 rounded-lg shadow-xl opacity-0 invisible transform scale-95 transition-all duration-200 origin-top-right right-0 z-50 flex flex-col overflow-hidden">
          
          <!-- Logged Out State -->
          <div id="header-menu-logged-out">
            <a href="/area-cliente/login" class="flex items-center gap-3 px-4 py-3 text-sm text-white hover:bg-white/5 transition-colors font-medium">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1" /></svg>
              Login
            </a>
          </div>

          <!-- Logged In State -->
          <div id="header-menu-logged-in" class="hidden">
            <div class="px-4 py-3 border-b border-white/5 bg-white/2">
              <h3 class="font-bold text-white text-sm mb-0.5">Il mio account</h3>
              <p id="header-user-email" class="text-xs text-gray-400 truncate">...</p>
            </div>
            
            <div class="py-2 flex flex-col">
              <a href="/area-cliente" class="flex items-center gap-3 px-4 py-2 text-sm text-white hover:bg-white/5 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                Area riservata
              </a>
              <a href="/area-cliente/ordini" class="flex items-center gap-3 px-4 py-2 text-sm text-white hover:bg-white/5 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                I miei ordini
              </a>
            </div>

            <div id="header-admin-section" class="hidden border-t border-white/5 py-2">
              <div class="px-4 py-1 flex items-center gap-2 mb-1">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                <span class="text-[10px] text-gray-500 font-bold uppercase tracking-widest">Amministrazione</span>
              </div>
              <a href="/admin" class="flex items-center gap-3 px-4 py-2 text-sm text-white hover:bg-white/5 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                Gestione
              </a>
            </div>

            <div class="border-t border-white/5 py-2 bg-white/2">
              <button id="header-btn-logout" class="w-full text-left flex items-center gap-3 px-4 py-2 text-sm text-red-400 hover:text-red-300 hover:bg-red-500/10 transition-colors font-medium">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" /></svg>
                Esci
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu Toggle Button -->
  <div class="flex items-center gap-4 lg:hidden">
    <!-- Mobile User Icon - Link directo al área cuando está logueado -->
    <a
      href="/area-cliente"
      class="text-gold hover:text-white transition-colors hidden"
      id="nav-area-cliente-mobile-icon"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        ><path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
        ></path></svg
      >
    </a>
    <button
      id="menu-toggle"
      class="text-white hover:text-gold focus:outline-none z-50"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-8 w-8"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>
</header>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 bg-dark z-40 hidden flex-col items-center justify-center text-white p-10"
>
  <button
    id="menu-close"
    class="absolute top-6 right-6 text-white text-5xl hover:text-gold"
    >&times;</button
  >

  <nav class="flex flex-col gap-6 text-center w-full">
    <a
      href="/"
      class="hidden text-2xl font-display uppercase tracking-widest hover:text-gold"
      >Home</a
    >
    <a
      href="/chi-siamo"
      class="text-2xl font-display uppercase tracking-widest hover:text-gold"
      >Chi Siamo</a
    >
    <a
      href="/gallery"
      class="text-2xl font-display uppercase tracking-widest hover:text-gold"
      >Gallery</a
    >

    <a
      href="/gift-card"
      class="text-2xl font-display uppercase tracking-widest hover:text-gold"
      >Gift Card</a
    >
    <a
      href="/menu"
      class="text-2xl font-display uppercase tracking-widest hover:text-gold"
      >Menu</a
    >
    <a
      href="/bar"
      class="hidden text-2xl font-display uppercase tracking-widest hover:text-gold"
      >Bar</a
    >

    <div class="h-px bg-white/10 my-4"></div>

    <div id="mobile-auth-section" class="flex flex-col gap-4">
      <button
        id="mobile-nav-logout"
        class="text-red-400 text-2xl font-display uppercase tracking-widest hidden"
        >Logout</button
      >
      <a
        href="/area-cliente/login"
        class="text-gold text-2xl font-display uppercase tracking-widest"
        id="mobile-nav-login">Login</a
      >
    </div>
  </nav>
</div>

<script>
  import { supabase } from "../lib/supabase";

  const menuToggle = document.getElementById("menu-toggle");
  const menuClose = document.getElementById("menu-close");
  const mobileMenu = document.getElementById("mobile-menu");

  const mobileIcon = document.getElementById("nav-area-cliente-mobile-icon");
  const mobileLogout = document.getElementById("mobile-nav-logout");
  const mobileLogin = document.getElementById("mobile-nav-login");
  
  // Custom User Dropdown Logic
  const dropdownTrigger = document.getElementById("header-user-trigger");
  const dropdownMenu = document.getElementById("header-user-menu");
  const caretIcon = document.getElementById("header-user-caret");
  
  if (dropdownTrigger && dropdownMenu && caretIcon) {
    dropdownTrigger.addEventListener("click", (e) => {
      e.stopPropagation();
      const isHidden = dropdownMenu.classList.contains("opacity-0");
      if (isHidden) {
        dropdownMenu.classList.remove("opacity-0", "invisible", "scale-95");
        dropdownMenu.classList.add("opacity-100", "scale-100");
        caretIcon.classList.add("-rotate-180");
      } else {
        dropdownMenu.classList.add("opacity-0", "invisible", "scale-95");
        dropdownMenu.classList.remove("opacity-100", "scale-100");
        caretIcon.classList.remove("-rotate-180");
      }
    });

    document.addEventListener("click", (e) => {
      if (!dropdownMenu.contains(e.target as Node) && !dropdownTrigger.contains(e.target as Node)) {
        dropdownMenu.classList.add("opacity-0", "invisible", "scale-95");
        dropdownMenu.classList.remove("opacity-100", "scale-100");
        caretIcon.classList.remove("-rotate-180");
      }
    });
  }

  async function updateAuthUI() {
    const guestEmail = localStorage.getItem("pachamama_guest_email");

    const {
      data: { session },
    } = await supabase.auth.getSession();

    const isLoggedIn = !!session || !!guestEmail;
    const isMasterAdmin = session?.user?.email === "admin@pachamama.com";
    const isTeamAdmin = session?.user?.user_metadata?.role === "admin";
    const isAdmin = isMasterAdmin || isTeamAdmin;

    // Desktop UI
    const loggedOutMenu = document.getElementById("header-menu-logged-out");
    const loggedInMenu = document.getElementById("header-menu-logged-in");
    const userInitials = document.getElementById("header-user-initials");
    const userIcon = document.getElementById("header-user-icon");
    const userEmailEl = document.getElementById("header-user-email");
    const adminSection = document.getElementById("header-admin-section");

    if (isLoggedIn) {
      if (loggedOutMenu) loggedOutMenu.classList.add("hidden");
      if (loggedInMenu) loggedInMenu.classList.remove("hidden");
      if (userInitials) {
        userInitials.classList.remove("hidden");
        userInitials.classList.add("flex");
      }
      if (userIcon) userIcon.classList.add("hidden");

      const email = session?.user?.email || guestEmail || "";
      if (userEmailEl) userEmailEl.innerText = email;
      if (userInitials && email) userInitials.innerText = email.substring(0, 2).toUpperCase();

      if (adminSection) {
         if (isAdmin) adminSection.classList.remove("hidden");
         else adminSection.classList.add("hidden");
      }

      // Mobile UI
      mobileIcon?.classList.remove("hidden");
      mobileLogout?.classList.remove("hidden");
      mobileLogin?.classList.add("hidden");
      
      if (isAdmin) {
        if (mobileIcon) mobileIcon.setAttribute("href", "/admin");
      } else {
        if (mobileIcon) mobileIcon.setAttribute("href", "/area-cliente");
      }
    } else {
      if (loggedOutMenu) loggedOutMenu.classList.remove("hidden");
      if (loggedInMenu) loggedInMenu.classList.add("hidden");
      if (userInitials) {
        userInitials.classList.add("hidden");
        userInitials.classList.remove("flex");
      }
      if (userIcon) userIcon.classList.remove("hidden");

      // Mobile UI
      mobileIcon?.classList.add("hidden");
      mobileLogout?.classList.add("hidden");
      mobileLogin?.classList.remove("hidden");
    }
  }

  updateAuthUI();

  document.getElementById("header-btn-logout")?.addEventListener("click", async () => {
    await supabase.auth.signOut();
    localStorage.removeItem("pachamama_guest_email");
    window.location.href = "/";
  });

  mobileLogout?.addEventListener("click", async () => {
    await supabase.auth.signOut();
    localStorage.removeItem("pachamama_guest_email");
    window.location.href = "/";
  });

  menuToggle?.addEventListener("click", () =>
    mobileMenu?.classList.remove("hidden"),
  );
  menuClose?.addEventListener("click", () =>
    mobileMenu?.classList.add("hidden"),
  );

  supabase.auth.onAuthStateChange(() => {
    updateAuthUI();
  });
</script>
