---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SectionPattern from "../components/SectionPattern.astro";

const title = "Menu Bar & Bevande | Pachamama Milano";
---

<Layout title={title}>
  <Header />

  <main
    class="text-white pt-[96px] pb-24 min-h-screen relative overflow-hidden bg-black"
  >
    <div class="w-full lg:max-w-screen-2xl lg:mx-auto lg:w-[85%]">
      <!-- Filtro por Etiquetas (Pro & Minimalista) -->
      <div
        class="px-6 flex flex-wrap justify-center gap-4 pt-8 pb-0 relative z-40 bg-black"
      >
        <div id="category-tags" class="flex flex-wrap justify-center gap-3">
          <!-- Dinamico -->
          <button
            data-category="all"
            class="category-tag active px-6 py-2 border border-white text-white font-display text-[10px] uppercase tracking-[0.2em] transition-all hover:bg-white hover:text-black rounded-none"
          >
            Tutte le bevande
          </button>
        </div>
      </div>

      <div
        id="bar-items-list"
        class="w-full px-4 md:px-6 mt-0 relative z-10 space-y-16"
      >
        <!-- Los productos se renderizarán aquí agrupados por categoría -->
      </div>
    </div>
  </main>

  <Footer />

  <style>
    @keyframes fade-in {
      from {
        opacity: 0;
        transform: translateY(10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
    .animate-fade-in {
      animation: fade-in 0.8s ease-out forwards;
    }
    .category-tag.active {
      background-color: white;
      color: black;
    }

    header {
      border-bottom: none !important;
      background-color: #000000 !important;
    }

    body {
      background-color: #000000 !important;
    }
  </style>

  <script>
    import { supabase } from "../lib/supabase";

    let categories: any[] = [];
    let items: any[] = [];
    const barList = document.getElementById("bar-items-list")!;
    const categoryTags = document.getElementById("category-tags")!;

    async function init() {
      try {
        const [catsRes, itemsRes] = await Promise.all([
          supabase
            .from("bar_categories")
            .select("*")
            .order("order", { ascending: true }),
          supabase
            .from("bar_items")
            .select("*")
            .eq("is_available", true)
            .order("order", { ascending: true }),
        ]);

        categories = catsRes.data || [];
        items = itemsRes.data || [];

        // Poblar Etiquetas
        categoryTags.innerHTML =
          '<button data-category="all" class="category-tag active px-6 py-2 border border-white text-white font-display text-[10px] uppercase tracking-[0.3em] transition-all hover:bg-white hover:text-black rounded-none">Tutte le bevande</button>' +
          categories
            .map(
              (cat) =>
                `<button data-category="${cat.id}" class="category-tag px-6 py-2 border border-white/20 text-white/50 font-display text-[10px] uppercase tracking-[0.3em] transition-all hover:border-white hover:text-white rounded-none">${cat.name}</button>`,
            )
            .join("");

        // Eventos de Filtro
        document.querySelectorAll(".category-tag").forEach((btn) => {
          btn.addEventListener("click", (e) => {
            const catId = (e.currentTarget as HTMLElement).dataset.category!;

            document.querySelectorAll(".category-tag").forEach((t) => {
              t.classList.remove("active", "bg-white", "text-black");
              t.classList.add("border-white/20", "text-white/50");
            });
            const target = e.currentTarget as HTMLElement;
            target.classList.add("active", "bg-white", "text-black");
            target.classList.remove("border-white/20", "text-white/50");

            renderItems(catId);
          });
        });

        renderItems("all");
      } catch (err) {
        console.error(err);
      }
    }

    function renderItems(catId: string) {
      barList.innerHTML = "";
      // Aseguramos que el contenedor sea una columna de secciones
      barList.className = "w-full px-6 mt-0 relative z-10 space-y-16";

      const activeCategories =
        catId === "all" ? categories : categories.filter((c) => c.id === catId);

      if (items.length === 0) {
        barList.innerHTML = `<div class="py-20 text-center opacity-50 italic">Nessun prodotto disponible.</div>`;
        return;
      }

      activeCategories.forEach((cat) => {
        const catItems = items.filter((i) => i.category_id === cat.id);

        if (catItems.length > 0) {
          const section = document.createElement("section");
          section.className = "animate-fade-in";

          section.innerHTML = `
                <h2 class="text-xl md:text-2xl font-display font-medium text-center uppercase tracking-[0.4em] text-white mt-8 mb-8">
                    ${cat.name}
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-1 gap-y-8">
                    ${catItems
                      .map(
                        (item) => `
                        <div class="group flex flex-col bg-dark overflow-hidden transition-all duration-500 h-full border border-white/10">
                            <div class="aspect-video overflow-hidden relative">
                                <img 
                                    src="${item.image_url || "https://placehold.co/600x400/1a1a1a/gold?text=Bevande"}" 
                                    alt="${item.title}"
                                    class="w-full h-full object-cover opacity-80 transition-opacity duration-700"
                                />
                            </div>

                            <div class="p-6 flex flex-col flex-grow">
                                <div class="flex justify-between items-start mb-2 gap-4">
                                    <h3 class="text-lg font-display font-bold uppercase tracking-tight leading-tight">
                                        ${item.title}
                                    </h3>
                                    <div class="text-xl font-display font-bold text-gold">
                                        €${item.price.toFixed(0)}
                                    </div>
                                </div>
                                <p class="text-gray-400 text-sm font-light leading-relaxed flex-grow">
                                    ${item.description || ""}
                                </p>
                            </div>
                        </div>
                    `,
                      )
                      .join("")}
                </div>
            `;
          barList.appendChild(section);
        }
      });
    }

    init();
  </script>
</Layout>
