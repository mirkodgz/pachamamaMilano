---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Ristorante peruviano a Milano, Pachamama! Un’esperienza unica di cucina novoandina.",
} = Astro.props;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts: Bebas Neue (Titles) & Montserrat (Text) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap"
      rel="stylesheet"
    />

    <!-- Dynamic Environment Variables for Client-Side Scripts (Docker fallback) -->
    <script
      is:inline
      define:vars={{
        PUBLIC_SUPABASE_URL:
          import.meta.env.PUBLIC_SUPABASE_URL ||
          (typeof process !== "undefined"
            ? process.env.PUBLIC_SUPABASE_URL || process.env.SUPABASE_URL
            : undefined) ||
          "https://dummy.supabase.co",
        PUBLIC_SUPABASE_ANON_KEY:
          import.meta.env.PUBLIC_SUPABASE_ANON_KEY ||
          (typeof process !== "undefined"
            ? process.env.PUBLIC_SUPABASE_ANON_KEY ||
              process.env.SUPABASE_ANON_KEY
            : undefined) ||
          "dummy_key",
      }}
    >
      window.env = window.env || {};
      window.env.PUBLIC_SUPABASE_URL = PUBLIC_SUPABASE_URL;
      window.env.PUBLIC_SUPABASE_ANON_KEY = PUBLIC_SUPABASE_ANON_KEY;
    </script>

    <title>{title}</title>
  </head>
  <body
    class="bg-dark text-white font-body antialiased selection:bg-gold selection:text-black"
  >
    <slot />
  </body>
</html>
